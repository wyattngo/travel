# Template for the Docker deploy environment.
# `./server-setup.sh env` copies this to .env.docker and fills in the blank
# secrets (APP_KEY, DB password) with freshly generated values.
# Shared by the `app` and `db` services.

# --- Laravel ---
APP_NAME="AuraTravel Kenya"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=travelvanlang
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
BROADCAST_DRIVER=log
MAIL_MAILER=log

# Seed the catalog on first boot (auto-skips once data exists)
DB_SEED=true

# --- MySQL container (mysql:8.0 image reads these) ---
MYSQL_DATABASE=travelvanlang
MYSQL_ROOT_PASSWORD=

# --- Host port the app is published on (maps to container :80) ---
APP_PORT=8000
